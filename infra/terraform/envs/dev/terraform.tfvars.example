# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — NEVER commit real values.
#
# Run:
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit terraform.tfvars — replace every <placeholder>
#   terraform init -backend-config=... (see backend.tf header for flags)
#   terraform plan -var-file=terraform.tfvars

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------

resource_group_name = "atlas-dev-rg"
location            = "westeurope"

tags = {
  project    = "atlas"
  managed-by = "terraform"
  env        = "dev"
}

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

vnet_name          = "atlas-vnet"
vnet_address_space = ["10.0.0.0/16"]

subnet_system_cidr   = "10.0.0.0/22"
subnet_workload_cidr = "10.0.4.0/22"
subnet_data_cidr     = "10.0.8.0/24"

# ---------------------------------------------------------------------------
# AKS
# ---------------------------------------------------------------------------

cluster_name       = "atlas-aks-dev"
kubernetes_version = "1.30"
dns_prefix         = "atlas-dev"

# Dev node pools — burstable SKUs, min=0 on workload for scale-to-zero
system_node_pool_vm_size    = "Standard_B2s"
system_node_pool_node_count = 1

workload_node_pool_vm_size   = "Standard_B4ms"
workload_node_pool_min_count = 0  # autoscaler can scale to zero off-hours
workload_node_pool_max_count = 3

# Azure AD group object IDs for cluster admin — replace with real IDs
admin_group_object_ids = ["<aad-group-object-id>"]

# ---------------------------------------------------------------------------
# Identity
# ---------------------------------------------------------------------------

kubernetes_namespace = "atlas-dev"

# Per-service managed identity + role assignment config.
# Scopes reference the Key Vault and Storage Account created by this root.
# Use `terraform output key_vault_id` / `terraform output storage_account_...`
# after first apply to fill in real resource IDs.
services = {
  gateway = {
    role_assignments = [
      { role_definition_name = "Key Vault Secrets User",   scope = "<key-vault-id>" },
      { role_definition_name = "Storage Blob Data Reader", scope = "<storage-account-id>" },
    ]
  }
  agent-runtime = {
    role_assignments = [
      { role_definition_name = "Key Vault Secrets User",        scope = "<key-vault-id>" },
      { role_definition_name = "Storage Blob Data Contributor", scope = "<storage-account-id>" },
    ]
  }
  mcp-doc-search = {
    role_assignments = [
      { role_definition_name = "Key Vault Secrets User", scope = "<key-vault-id>" },
    ]
  }
  mcp-citations = {
    role_assignments = [
      { role_definition_name = "Key Vault Secrets User", scope = "<key-vault-id>" },
    ]
  }
  mlflow = {
    role_assignments = [
      { role_definition_name = "Key Vault Secrets User",        scope = "<key-vault-id>" },
      { role_definition_name = "Storage Blob Data Contributor", scope = "<storage-account-id>" },
    ]
  }
  otel-collector = {
    role_assignments = [
      { role_definition_name = "Key Vault Secrets User", scope = "<key-vault-id>" },
    ]
  }
}

# gateway_identity_client_id is only needed on the first bootstrap apply before
# the identity module has run.  Leave empty after the first full apply —
# the env root resolves it automatically from module.identity.identity_client_ids.
gateway_identity_client_id = ""

# ---------------------------------------------------------------------------
# Secrets (Key Vault)
# ---------------------------------------------------------------------------

# Must be globally unique, 3-24 chars, alphanumeric + hyphens.
key_vault_name = "atlas-kv-dev-<unique-suffix>"

# From: az account show --query tenantId -o tsv
tenant_id = "<aad-tenant-id>"

# Secret NAMES only — values are set out-of-band, never in Terraform.
secret_names = [
  "atlas-pg-password",
  "atlas-redis-password",
  "atlas-openai-api-key",
  "atlas-anthropic-api-key",
]

# ---------------------------------------------------------------------------
# Data (PostgreSQL + Redis)
# ---------------------------------------------------------------------------

# Must be globally unique, 3-63 chars, lowercase alphanumeric + hyphens.
pg_server_name    = "atlas-pg-dev-<unique-suffix>"
pg_admin_username = "atlasadmin"

# ---------------------------------------------------------------------------
# Storage (Blob + ACR)
# ---------------------------------------------------------------------------

# Storage Account: globally unique, 3-24 chars, lowercase alphanumeric only.
storage_account_name = "atlasdev<unique-suffix>"

# ACR: globally unique, 5-50 chars, alphanumeric only.
acr_name = "atlasdev<unique-suffix>"
