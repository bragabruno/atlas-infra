# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — NEVER commit real values.

resource_group_name = "atlas-dev-rg"
location            = "westeurope"

# Key Vault — must be globally unique; 3–24 chars, alphanumeric + hyphens
key_vault_name             = "atlas-kv-dev-<unique-suffix>"
key_vault_sku_name         = "standard"
soft_delete_retention_days = 90
purge_protection_enabled   = false

# Azure AD tenant — from `az account show --query tenantId`
tenant_id = "<aad-tenant-id>"

# Subnet and VNet — from network module outputs
subnet_data_id = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Network/virtualNetworks/atlas-vnet/subnets/data"
vnet_id        = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Network/virtualNetworks/atlas-vnet"

# Secret NAMES only — values are set out-of-band, never in Terraform
secret_names = [
  "atlas-pg-password",
  "atlas-redis-password",
  "atlas-openai-api-key",
  "atlas-anthropic-api-key",
]

# Kubernetes namespace and identity — from identity module outputs
kubernetes_namespace = "atlas"
identity_client_id   = "<uami-client-id-from-identity-module>"

tags = {
  project    = "atlas"
  managed-by = "terraform"
  module     = "secrets"
  env        = "dev"
}
